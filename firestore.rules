rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts (blog + noticias): leitura pública apenas de publicados
    match /posts/{postId} {
      allow read: if resource.data.status == 'published';
      allow write: if request.auth != null;
    }

    // Configurações do site: leitura pública, escrita apenas admin
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Envios de contato: qualquer um pode criar, admin pode ler/gerenciar
    match /contact_submissions/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
